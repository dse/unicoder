#!/usr/bin/env perl
use warnings;
use strict;
use FindBin qw($Bin);
use lib "$Bin/../lib";
use Unicode::UCD qw(charinfo);
use Unicoder::Search qw(unicoder_load_db unicoder_search_db);
use Unicoder::Print qw(char_line_as_string);
binmode(STDOUT, ":utf8");

our $all = 0;
our $print_char = 0;
our $print_category = 0;
our $print_gc = 0;
our $decimal;
our $hexadecimal;
our $octal;
our $adobe;

use Getopt::Long;
Getopt::Long::Configure(qw(gnu_getopt));
Getopt::Long::GetOptions(
    'a|all' => \$all,
    'k|category|print-category' => \$print_category,
    'gc' => \$print_gc,
    'c|char|print-char' => \$print_char,
    'd|decimal' => \$decimal,
    'x|hexadecimal' => \$hexadecimal,
    'o|octal' => \$octal,
    'A|adobe' => \$adobe,
    'help|?' => sub { usage(); exit(0); },
) or die(":-(\n");

sub usage { print(<<"EOF"); }
charsearch [OPTION ...] [KEYWORD ...]
    -a, --all       Print all results.
    -c, --char      Display characters.
    -k, --category  Display Unicode general category names.
        --gc        Display Unicode genearl category abbreviations.
    -d, --decimal   Print decimal codes.
    -o, --octal     Print octal codes.
    -A, --adobe     Print Adobe glyph names.
advanced keyword operators:
    require:devangari not:leader wholeword:leader startswith:lead
operators can be combined:
    require:wholeword:leader
EOF

unicoder_load_db();

my @results = unicoder_search_db(\@ARGV);
my $result_count = scalar @results;
if (!$all && $result_count > 20) {
    splice(@results, 20);
}

foreach my $result (@results) {
    my ($codepoint, $score) = ($result->{codepoint}, $result->{score});
    printf("%s\n", char_line_as_string($codepoint,
                                       print_char => $print_char,
                                       print_gc => $print_gc,
                                       print_category => $print_category,
                                       octal => $octal,
                                       decimal => $decimal,
                                       adobe => $adobe));
}
if ($result_count > 20 && !$all) {
    printf("# Use --all to list all %d results.\n", $result_count);
}
